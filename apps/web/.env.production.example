# Production Environment Variables
# Copy this to .env.production and fill in your production values

# Database (Neon, Supabase, or any PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&connect_timeout=30&pool_timeout=30"

# Auth (NextAuth v5) - CRITICAL: Generate a secure secret!
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_SECRET_MIN_32_CHARS"
AUTH_URL="https://your-production-domain.com"
NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

# GitHub OAuth (Create production app at github.com/settings/developers)
GITHUB_ID="your-production-github-oauth-client-id"
GITHUB_SECRET="your-production-github-oauth-client-secret"

# Redis (Upstash - for rate limiting and caching)
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# AI (Google Gemini - for content moderation and features)
GEMINI_API_KEY="your-gemini-api-key"

# Background Jobs (Inngest - for async processing)
CRON_SECRET="your-cron-secret"
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Node Environment
NODE_ENV="production"
