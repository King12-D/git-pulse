generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  githubId  String?  @unique
  username  String?  @unique // GitHub login or email for email/password users
  email     String?  @unique
  password  String?  // Hashed password for email/password authentication
  name      String?
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
  comments  Comment[]
  reactions Reaction[]
  followers Follow[]  @relation("following") // users who follow this user
  following Follow[]  @relation("follower")  // users this user follows
  notifications Notification[]
  apiKey      String?  @unique  // hashed api key for programmatic access
  accessToken String?  // github oauth token, stored server-side only — never sent to client
  isAdmin     Boolean  @default(false)
  statusEmoji String?
  statusText  String?
  showActivity      Boolean @default(true)
  showContributions Boolean @default(true)
}

model Post {
  id          String   @id @default(cuid())
  content     String
  type        String   @default("standard") // "standard" | "ship"
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // JSON fields for embedded data
  repoEmbed   Json?    // { name, description, language, languageColor, stars, forks }
  shipDetails Json?    // { version, changelog }

  // Enhanced post fields
  images      String[] @default([])
  hashtags    String[] @default([])
  repoUrl     String?

  // Repost functionality
  repostOfId  String?
  repostOf    Post?    @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts     Post[]   @relation("Reposts")

  comments    Comment[]
  reactions   Reaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([repostOfId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Self-referential for nested threads
  parentId  String?
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentThread")

  createdAt DateTime  @default(now())

  @@index([postId])
  @@index([parentId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // "👍", "🚀", "❤️", etc.
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId, emoji]) // one reaction type per user per post
  @@index([postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId]) // can't follow the same person twice
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "TRENDING", "BADGE", "FOLLOW", "SYSTEM"
  message   String
  read      Boolean  @default(false)
  linkUrl   String?  // Optional URL to navigate to when clicked
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
